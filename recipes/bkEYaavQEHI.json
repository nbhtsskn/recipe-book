  "steps": [
    {
      "step": 1,
      "text": "ご飯200gにゆかりふりかけ大さじ1/2を混ぜ、5等分に握る。",
      "point": "ゆかりを混ぜることで酸味と香りが加わり、豚バラの甘辛タレとの相性が抜群。おにぎりは固めに握った方がタレを絡めても崩れにくい。"
    },
    {
      "step": 2,
      "text": "豚バラ肉5枚100gを1枚ずつおにぎりに巻き、サラダ油で巻き終わりから全体を焼く。",
      "point": "巻き終わりから焼くことで豚バラが解けにくくなる。香ばしく焼き色がつくまでしっかり焼くことが美味しさの秘訣。"
    },
    {
      "step": 3,
      "text": "醤油大さじ1と1/2・みりん大さじ1・酒大さじ1/2・砂糖大さじ1・味の素3振りを混ぜたタレを入れて煮詰め、全体に絡めたら紅ショウガ・いりごまをかけて完成。",
      "point": "タレを煮詰めながら絡めることで照りが出て全人類が好きな甘辛な仕上がりになる。"
    }
  ]
