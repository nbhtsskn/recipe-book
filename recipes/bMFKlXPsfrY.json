  "steps": [
    {
      "step": 1,
      "text": "木綿豆腐350gに片栗粉大さじ1/2・塩コショウをまぶす。サラダ油大さじ1で豆腐を炒め、しっかり水分を飛ばす。",
      "point": "豆腐に片栗粉をまぶしてから炒めることで崩れにくくなり食感も良くなる。しっかり水分を飛ばすことがチャンプルーの旨みを凝縮させるポイント。"
    },
    {
      "step": 2,
      "text": "塩コショウした豚肉120gを加えて炒め、もやし100g・ニラ50gを加えてさらに炒める。",
      "point": "豚肉を先に炒めて旨みを出してから野菜を加える。ニラは最後に入れることで食感と香りが保たれる。"
    },
    {
      "step": 3,
      "text": "酒大さじ1・白だし大さじ1と小さじ2・醤油小さじ1・黒コショウを加えて炒め合わせ、鰹節をかけて完成。",
      "point": "白だしが沖縄風とは一味違う旨みを生み出す。全体をざっくり和えるだけで完成する手軽さも魅力。"
    }
  ]
